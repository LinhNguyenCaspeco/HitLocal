{
  "manifest_version": 3,
  "name": "HitLocal",
  "version": "1.0.0",
  "description": "Replay network requests against your local development server with one click.",
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.caspeco.net/*",
    "https://localhost.caspeco.net/*"
  ],    
  "icons": {
    "16":  "icons/icon16.png",                                                                                                                                                                                                                                                                                                  
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
